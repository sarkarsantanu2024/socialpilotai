# ─────────────────────────────────────────────────────────────
# SocialPilot AI — environment variables
# Copy to `.env` for local dev. The app runs FULLY in DEMO_MODE
# with NO values set — every external call has a mock fallback.
# ─────────────────────────────────────────────────────────────

# Master switch. When true (or when creds are missing) every external
# call returns realistic fake data so the whole app is demoable for ₹0.
NEXT_PUBLIC_DEMO_MODE=true

# --- Database (real path only; DEMO_MODE needs no DB) ---
# Neon Postgres free tier connection string
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- AI: Google Gemini (free tier) ---
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-1.5-flash-8b

# --- Post images: Pexels stock photos (free) ---
# Get a free key at https://www.pexels.com/api/ (2-min signup).
# If left blank, the app falls back to free keyword stock (LoremFlickr) — no key needed.
PEXELS_API_KEY=

# --- Facebook Graph + Marketing API (development mode) ---
# Create a Meta app at https://developers.facebook.com → add "Facebook Login".
# See FACEBOOK_SETUP.md. Put real values in .env.local (NOT here) + restart.
FB_APP_ID=
FB_APP_SECRET=
FB_GRAPH_VERSION=v20.0
# Must EXACTLY match a Valid OAuth Redirect URI in the Meta app settings.
FB_REDIRECT_URI=http://localhost:3001/api/auth/facebook/callback

# --- Object storage: Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=socialpilot-media

# --- Email: Resend or Brevo free tier ---
RESEND_API_KEY=

# --- Payments: Razorpay (stubbed behind a flag) ---
PAYMENTS_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Token encryption (32-byte hex for AES-256-GCM) ---
TOKEN_ENC_KEY=

# --- Scheduled publishing (cron) ---
# Secret the cron caller must send (Authorization: Bearer <secret> or ?secret=).
# Set the same value in your Vercel/GitHub Actions cron job. See vercel.json.
CRON_SECRET=

# --- Lead Ads webhook ---
# Token echoed back during Meta webhook verification. Use the SAME value in the
# Meta app → Webhooks → leadgen subscription. Callback URL:
#   https://<your-domain>/api/webhooks/leadgen
WEBHOOK_VERIFY_TOKEN=socialpilot-verify
